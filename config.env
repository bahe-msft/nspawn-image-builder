# nspawn-image-builder configuration

# Image name (used for tarball filename and machine name)
IMAGE_NAME="nspawn-base"

# Ubuntu release codename
BASE_DISTRO="noble"

# Mirror for debootstrap
BASE_MIRROR="http://archive.ubuntu.com/ubuntu"

# Extra packages to install (space-separated)
EXTRA_PACKAGES="curl wget vim less htop net-tools iputils-ping dnsutils ca-certificates"

# GHCR (GitHub Container Registry) settings
# Override GHCR_REPO to push to a different registry path
GHCR_REGISTRY="ghcr.io"
GHCR_REPO=""  # e.g. "bahe-msft/nspawn-image-builder/nspawn-base" — auto-derived if empty
GHCR_TAG="latest"
