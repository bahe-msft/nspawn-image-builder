# nspawn-image-builder default configuration
#
# This file is used when build.sh is called without --variant.
# It sources the base variant config for a single source of truth.
# Override individual settings below the source line if needed.

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "${SCRIPT_DIR}/variants/base.conf"

# GHCR (GitHub Container Registry) settings
# Override GHCR_REPO to push to a different registry path
GHCR_REGISTRY="ghcr.io"
GHCR_REPO=""  # e.g. "bahe-msft/nspawn-image-builder/nspawn-base" — auto-derived if empty
GHCR_TAG="latest"
